{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.com/remote-support/update-root-v1.json",
  "title": "Remote Support Update Trust Root",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "signed",
    "signatures"
  ],
  "properties": {
    "signed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "rootVersion",
        "issuedAt",
        "expiresAt",
        "consistentSnapshot",
        "keys",
        "roles"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "rootVersion": {
          "type": "integer",
          "minimum": 1
        },
        "issuedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        },
        "consistentSnapshot": {
          "const": true
        },
        "keys": {
          "type": "object",
          "minProperties": 2,
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "algorithm",
              "publicKey"
            ],
            "properties": {
              "algorithm": {
                "const": "ed25519"
              },
              "publicKey": {
                "type": "string",
                "minLength": 40,
                "maxLength": 128
              }
            }
          }
        },
        "roles": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "root",
            "targets"
          ],
          "properties": {
            "root": {
              "$ref": "#/$defs/role"
            },
            "targets": {
              "$ref": "#/$defs/role"
            }
          }
        }
      }
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "$ref": "#/$defs/signature"
      }
    }
  },
  "$defs": {
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "keyIds",
        "threshold"
      ],
      "properties": {
        "keyIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "threshold": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "keyId",
        "algorithm",
        "signature"
      ],
      "properties": {
        "keyId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "algorithm": {
          "const": "ed25519"
        },
        "signature": {
          "type": "string",
          "minLength": 64,
          "maxLength": 256
        }
      }
    }
  }
}

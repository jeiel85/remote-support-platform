{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.com/remote-support/client-config-v1.json",
  "title": "Remote Support Client Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "apiBaseUrl", "signalingUrl", "update", "limits"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "apiBaseUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
    "signalingUrl": { "type": "string", "format": "uri", "pattern": "^wss://" },
    "environment": { "enum": ["development", "staging", "production"] },
    "operatorOidc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority", "clientId", "scopes"],
      "properties": {
        "authority": { "type": "string", "format": "uri", "pattern": "^https://" },
        "clientId": { "type": "string", "minLength": 1, "maxLength": 200 },
        "scopes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 128 }
        }
      }
    },
    "update": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifestUrl", "channel", "trustedRootVersion"],
      "properties": {
        "manifestUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
        "channel": { "enum": ["internal", "canary", "stable"] },
        "trustedRootVersion": { "type": "integer", "minimum": 1 },
        "automaticCheck": { "type": "boolean" }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxControlMessageBytes", "maxFileChunkBytes", "maxClipboardUtf8Bytes", "maxFileBytes"],
      "properties": {
        "maxControlMessageBytes": { "type": "integer", "minimum": 4096, "maximum": 1048576 },
        "maxFileChunkBytes": { "type": "integer", "minimum": 16384, "maximum": 1048576 },
        "maxClipboardUtf8Bytes": { "type": "integer", "minimum": 1024, "maximum": 1048576 },
        "maxFileBytes": { "type": "integer", "minimum": 1, "maximum": 1099511627776 }
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "localLogLevel": { "enum": ["Error", "Warning", "Information", "Debug"] },
        "allowUserSupportBundle": { "type": "boolean" }
      }
    }
  }
}

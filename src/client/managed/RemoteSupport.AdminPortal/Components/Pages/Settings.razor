@page "/settings"
@inject ControlPlaneBffClient Api

<PageTitle>설정 · Remote Support</PageTitle>
<h1>테넌트 설정</h1>
<p class="lead">녹화는 Attended GA에서 항상 비활성화됩니다.</p>
@if (settings is null) { <p>테넌트를 먼저 선택하세요.</p> }
else {
<section class="panel narrow">
    <form method="post" action="/actions/settings">
        <AntiforgeryToken />
        <input type="hidden" name="settingsVersion" value="@settings.SettingsVersion" />
        <label for="retention">보존 기간(일)</label>
        <input id="retention" name="retentionDays" type="number" min="1" max="3650" value="@settings.RetentionDays" required />
        <label for="file-limit">파일 전송 제한(바이트)</label>
        <input id="file-limit" name="fileSizeLimitBytes" type="number" min="0" value="@settings.FileSizeLimitBytes" required />
        <label><input type="checkbox" disabled checked="@settings.RecordingEnabled" /> 녹화 사용(현재 릴리스에서 잠김)</label>
        <button type="submit">설정 저장</button>
    </form>
</section>
}

@code {
    private TenantSettingsView? settings;
    protected override async Task OnInitializedAsync() => settings = await Api.GetSettings();
}

@page "/audit"
@inject ControlPlaneBffClient Api

<PageTitle>감사 · Remote Support</PageTitle>
<h1>감사 기록</h1>
<p class="lead">체인 상태: <strong class="@(audit?.ChainValid == true ? "status-ok" : "status-bad")">@(audit?.ChainValid == true ? "검증됨" : "확인 필요")</strong></p>
<section class="panel table-wrap">
@if (audit is null) { <p>테넌트를 먼저 선택하세요.</p> }
else { <table><thead><tr><th>순번</th><th>시간</th><th>범주</th><th>작업</th><th>결과</th></tr></thead><tbody>
@foreach (AuditEventView item in audit.Items) {
    <tr><td>@item.ChainSequence</td><td>@item.OccurredAt.ToString("u")</td><td>@item.Category</td><td>@item.Action</td><td>@item.Outcome</td></tr>
}
</tbody></table> }
</section>

@code {
    private PagedAuditView? audit;
    protected override async Task OnInitializedAsync() => audit = await Api.GetAudit();
}

@page "/policies"
@inject ControlPlaneBffClient Api

<PageTitle>정책 · Remote Support</PageTitle>
<h1>접근 정책</h1>
<p class="lead">정책 버전은 불변이며 deny 규칙이 항상 우선합니다.</p>
<section class="panel">
    <h2>초안 만들기</h2>
    <form method="post" action="/actions/policies">
        <AntiforgeryToken />
        <label for="policy-name">정책 이름</label><input id="policy-name" name="name" required maxlength="200" />
        <label for="policy-document">정책 JSON</label>
        <textarea id="policy-document" name="document" rows="12" spellcheck="false" required>@ExamplePolicy</textarea>
        <button type="submit">검증 후 초안 저장</button>
    </form>
</section>
<section class="panel table-wrap">
    <h2>정책 목록</h2>
    @if (policies is null) { <p>테넌트를 먼저 선택하세요.</p> }
    else { <table><thead><tr><th>이름</th><th>상태</th><th>활성 버전</th><th>리소스 버전</th></tr></thead><tbody>
    @foreach (PolicyView policy in policies) { <tr><td>@policy.Name</td><td>@policy.Status</td><td>@policy.ActiveVersion</td><td>@policy.ResourceVersion</td></tr> }
    </tbody></table> }
</section>

@code {
    private const string ExamplePolicy = """
    {"schemaVersion":1,"rules":[{"id":"attended-default","effect":"ALLOW","subjects":{"roles":["OPERATOR"]},"resources":{"allDevices":true},"sessionTypes":["ATTENDED"],"scopes":["VIEW_SCREEN"],"conditions":{"requireLocalConsent":true}}]}
    """;
    private PolicyView[]? policies;
    protected override async Task OnInitializedAsync() => policies = await Api.GetPolicies();
}

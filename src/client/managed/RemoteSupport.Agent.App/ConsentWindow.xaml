<Window x:Class="RemoteSupport.Agent.App.ConsentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Remote support consent" Width="520" Height="560"
        MinWidth="420" MinHeight="460" WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock FontSize="24" FontWeight="SemiBold" Text="Remote support request"
                   AutomationProperties.Name="Remote support consent request" />
        <StackPanel Grid.Row="1" Margin="0,20,0,0">
            <TextBlock Text="Verified operator" FontWeight="SemiBold" />
            <TextBlock Text="{Binding OperatorDisplayName}" FontSize="18"
                       AutomationProperties.Name="Verified operator name" />
            <TextBlock Text="{Binding TenantDisplayName}" Margin="0,4,0,0"
                       AutomationProperties.Name="Verified organization name" />
            <TextBlock Text="{Binding VerificationText}" Margin="0,4,0,0" FontWeight="SemiBold"
                       AutomationProperties.Name="Organization verification state" />
        </StackPanel>
        <TextBlock Grid.Row="2" Margin="0,20,0,8" Text="Requested permissions" FontWeight="SemiBold" />
        <ListBox Grid.Row="3" ItemsSource="{Binding RequestedScopeLabels}"
                 AutomationProperties.Name="Requested permissions" IsTabStop="False" />
        <Grid Grid.Row="4" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="{Binding ExpiryText}"
                       AutomationProperties.Name="Request expiry" />
            <Button Grid.Column="1" MinWidth="100" Margin="8,0" Padding="14,8" Content="Deny"
                    IsCancel="True" Click="DenyClicked" AutomationProperties.Name="Deny remote support" />
            <Button Grid.Column="2" MinWidth="100" Padding="14,8" Content="Approve"
                    IsDefault="True" Click="ApproveClicked" AutomationProperties.Name="Approve selected remote support permissions" />
        </Grid>
    </Grid>
</Window>

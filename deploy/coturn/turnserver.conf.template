fingerprint
realm={{TURN_REALM}}
server-name={{TURN_REALM}}
use-auth-secret
static-auth-secret={{TURN_SHARED_SECRET}}
stale-nonce=600
max-allocate-lifetime=600

listening-port=3478
tls-listening-port=5349
{{LISTENER_POLICY}}
listening-ip={{LISTENING_IP}}
relay-ip={{RELAY_IP}}
external-ip={{EXTERNAL_IP}}/{{RELAY_IP}}
min-port={{MIN_RELAY_PORT}}
max-port={{MAX_RELAY_PORT}}

cert=/run/secrets/turn_fullchain.pem
pkey=/run/secrets/turn_private_key.pem
no-tlsv1
no-tlsv1_1
cipher-list=DEFAULT@SECLEVEL=2

no-cli
no-multicast-peers
no-software-attribute
no-tcp-relay
secure-stun
check-origin-consistency

denied-peer-ip=0.0.0.0-0.255.255.255
denied-peer-ip=10.0.0.0-10.255.255.255
denied-peer-ip=100.64.0.0-100.127.255.255
denied-peer-ip=127.0.0.0-127.255.255.255
denied-peer-ip=169.254.0.0-169.254.255.255
denied-peer-ip=172.16.0.0-172.31.255.255
denied-peer-ip=192.0.0.0-192.0.0.255
denied-peer-ip=192.168.0.0-192.168.255.255
denied-peer-ip=198.18.0.0-198.19.255.255
denied-peer-ip=224.0.0.0-255.255.255.255
denied-peer-ip=::1-::1
denied-peer-ip=fc00::-fdff:ffff:ffff:ffff:ffff:ffff:ffff:ffff
denied-peer-ip=fe80::-febf:ffff:ffff:ffff:ffff:ffff:ffff:ffff
denied-peer-ip=ff00::-ffff:ffff:ffff:ffff:ffff:ffff:ffff:ffff
{{EXTRA_DENIED_PEERS}}

user-quota={{USER_QUOTA}}
total-quota={{TOTAL_QUOTA}}
max-bps={{MAX_BPS}}
bps-capacity={{BPS_CAPACITY}}

prometheus
prometheus-port=9641
redis-statsdb="{{REDIS_STATSDB}}"

log-file=stdout
simple-log
new-log-timestamp

{
  "Environment": "Development",
  "PublicBaseUrl": "https://api.example.test",
  "Database": {
    "ConnectionStringSecretRef": "secret://remote-support/db",
    "CommandTimeoutSeconds": 30
  },
  "Authentication": {
    "Authority": "https://identity.example.test",
    "Audience": "remote-support-api",
    "RequiredMfaClaim": "mfa"
  },
  "Sessions": {
    "PendingLifetimeSeconds": 600,
    "ConsentLifetimeSeconds": 120,
    "PeerTokenLifetimeSeconds": 900,
    "ReconnectGraceSeconds": 30,
    "MaxSessionHours": 8
  },
  "Turn": {
    "CredentialSecretRef": "secret://remote-support/turn-rest",
    "CredentialLifetimeSeconds": 900,
    "Regions": [
      {
        "Name": "kr-seoul",
        "Urls": [
          "turn:turn.example.test:3478?transport=udp",
          "turns:turn.example.test:5349?transport=tcp"
        ]
      }
    ]
  },
  "RateLimits": {
    "CreateSessionPerIpPerMinute": 10,
    "ResolveCodePerIpPerMinute": 20,
    "ResolveCodePerOperatorPerMinute": 20
  },
  "Telemetry": {
    "OtlpEndpoint": "http://otel-collector:4317",
    "LogSensitiveDiagnostics": false
  }
}

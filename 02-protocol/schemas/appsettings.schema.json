{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.com/remote-support/appsettings-v1.json",
  "title": "Remote Support Server Settings",
  "type": "object",
  "additionalProperties": false,
  "required": ["Environment", "PublicBaseUrl", "Database", "Authentication", "Sessions", "Turn", "RateLimits", "Telemetry"],
  "properties": {
    "Environment": { "enum": ["Development", "Staging", "Production"] },
    "PublicBaseUrl": { "type": "string", "format": "uri" },
    "Database": {
      "type": "object", "additionalProperties": false,
      "required": ["ConnectionStringSecretRef", "CommandTimeoutSeconds"],
      "properties": {
        "ConnectionStringSecretRef": { "type": "string", "minLength": 1 },
        "CommandTimeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 300 }
      }
    },
    "Authentication": {
      "type": "object", "additionalProperties": false,
      "required": ["Authority", "Audience", "RequiredMfaClaim"],
      "properties": {
        "Authority": { "type": "string", "format": "uri" },
        "Audience": { "type": "string", "minLength": 1 },
        "RequiredMfaClaim": { "type": "string", "minLength": 1 }
      }
    },
    "Sessions": {
      "type": "object", "additionalProperties": false,
      "required": ["PendingLifetimeSeconds", "ConsentLifetimeSeconds", "PeerTokenLifetimeSeconds", "ReconnectGraceSeconds", "MaxSessionHours"],
      "properties": {
        "PendingLifetimeSeconds": { "type": "integer", "minimum": 60, "maximum": 3600 },
        "ConsentLifetimeSeconds": { "type": "integer", "minimum": 30, "maximum": 600 },
        "PeerTokenLifetimeSeconds": { "type": "integer", "minimum": 60, "maximum": 3600 },
        "ReconnectGraceSeconds": { "type": "integer", "minimum": 5, "maximum": 300 },
        "MaxSessionHours": { "type": "integer", "minimum": 1, "maximum": 24 }
      }
    },
    "Turn": {
      "type": "object", "additionalProperties": false,
      "required": ["CredentialSecretRef", "CredentialLifetimeSeconds", "Regions"],
      "properties": {
        "CredentialSecretRef": { "type": "string", "minLength": 1 },
        "CredentialLifetimeSeconds": { "type": "integer", "minimum": 60, "maximum": 3600 },
        "Regions": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["Name", "Urls"],
            "properties": {
              "Name": { "type": "string", "minLength": 1, "maxLength": 64 },
              "Urls": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
            }
          }
        }
      }
    },
    "RateLimits": {
      "type": "object", "additionalProperties": false,
      "required": ["CreateSessionPerIpPerMinute", "ResolveCodePerIpPerMinute", "ResolveCodePerOperatorPerMinute"],
      "properties": {
        "CreateSessionPerIpPerMinute": { "type": "integer", "minimum": 1, "maximum": 10000 },
        "ResolveCodePerIpPerMinute": { "type": "integer", "minimum": 1, "maximum": 10000 },
        "ResolveCodePerOperatorPerMinute": { "type": "integer", "minimum": 1, "maximum": 10000 }
      }
    },
    "Telemetry": {
      "type": "object", "additionalProperties": false,
      "required": ["OtlpEndpoint", "LogSensitiveDiagnostics"],
      "properties": {
        "OtlpEndpoint": { "type": "string", "format": "uri" },
        "LogSensitiveDiagnostics": { "const": false }
      }
    }
  }
}

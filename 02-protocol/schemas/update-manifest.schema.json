{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.com/remote-support/update-manifest-v1.json",
  "title": "Remote Support Signed Update Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "signed",
    "signatures"
  ],
  "properties": {
    "signed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "product",
        "channel",
        "version",
        "releaseSequence",
        "minimumAllowedSequence",
        "issuedAt",
        "expiresAt",
        "artifacts",
        "rootVersion"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "product": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "channel": {
          "enum": [
            "internal",
            "canary",
            "stable"
          ]
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "releaseSequence": {
          "type": "integer",
          "minimum": 1
        },
        "minimumAllowedSequence": {
          "type": "integer",
          "minimum": 0
        },
        "rollout": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "percentage",
            "seedVersion"
          ],
          "properties": {
            "percentage": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            "seedVersion": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "issuedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        },
        "releaseNotesUrl": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "architecture",
              "packageType",
              "url",
              "size",
              "sha256",
              "authenticodeSignerThumbprint"
            ],
            "properties": {
              "architecture": {
                "enum": [
                  "x64",
                  "arm64"
                ]
              },
              "packageType": {
                "enum": [
                  "PORTABLE_AGENT",
                  "OPERATOR_INSTALLER",
                  "MANAGED_HOST_INSTALLER"
                ]
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "size": {
                "type": "integer",
                "minimum": 1
              },
              "sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "authenticodeSignerThumbprint": {
                "type": "string",
                "minLength": 40,
                "maxLength": 128
              },
              "minimumOsBuild": {
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 64
              }
            }
          }
        },
        "rootVersion": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "keyId",
          "algorithm",
          "signature"
        ],
        "properties": {
          "keyId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "algorithm": {
            "enum": [
              "ed25519",
              "rsa-pss-sha256"
            ]
          },
          "signature": {
            "type": "string",
            "minLength": 64,
            "maxLength": 2048,
            "description": "Base64url signature over RFC 8785 canonical JSON of signed, prefixed by the RSP-UPDATE-MANIFEST-V1 domain separator."
          }
        }
      }
    }
  }
}
